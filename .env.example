# Reference for every environment variable AegisVault's services read.
# Not loaded automatically - docker-compose.yml and render.yaml set these
# directly. This file exists so all the options are documented in one place
# instead of scattered across code defaults, docker-compose.yml, and
# render.yaml.

# Which process docker/entrypoint.sh should run in this container.
# One of: backend, waf, dashboard
SERVICE=dashboard

# Ports each service binds to. Most PaaS platforms (Render, etc.) inject
# their own PORT env var, which every service prefers over these when set.
BACKEND_PORT=8000
WAF_PORT=5000
DASHBOARD_PORT=5001

# Host to bind to inside the container - almost always 0.0.0.0.
BACKEND_HOST=0.0.0.0
WAF_HOST=0.0.0.0
DASHBOARD_HOST=0.0.0.0

# Where the WAF forwards allowed requests. In docker-compose this is the
# backend service's Docker-network hostname; on a PaaS it's that service's
# public URL (only known after its first deploy).
BACKEND_URL=http://localhost:8000

# MongoDB connection string. docker-compose points this at the local mongo
# container; a hosted deploy needs a MongoDB Atlas (or similar) connection
# string instead, since most PaaS platforms have no native Mongo add-on.
MONGODB_URI=mongodb://localhost:27017

# Path to waf_settings.json (rate limiting, ML threshold, plugins, rules) -
# shared and hot-reloaded by both waf and dashboard.
WAF_SETTINGS_FILE=/app/waf_settings.json

# Which trained model file to load from waf/ml_model/waf_text/.
# One of: predictor_svc.joblib, predictor_lr.joblib, predictor_rf.joblib
ACTIVE_MODEL_FILE=predictor_lr.joblib
